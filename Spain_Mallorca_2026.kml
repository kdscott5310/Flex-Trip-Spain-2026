<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>Spain &amp; Mallorca 2026 — Group Trip</name>
  <description>All venues for BCN · Mallorca · Ibiza · BCN Finale — May 2026. Color coded by leg. Import into Google My Maps.</description>
  <Style id="style_bcn">
    <IconStyle>
      <color>ff5a38d4</color>
      <scale>1.1</scale>
      <Icon><href>http://maps.google.com/mapfiles/kml/paddle/red-circle.png</href></Icon>
    </IconStyle>
    <LabelStyle><scale>0.9</scale></LabelStyle>
    <BalloonStyle>
      <text><![CDATA[<b>$[name]</b><br/>$[description]]]></text>
    </BalloonStyle>
  </Style>
  <Style id="style_mal">
    <IconStyle>
      <color>ff6a8c1e</color>
      <scale>1.1</scale>
      <Icon><href>http://maps.google.com/mapfiles/kml/paddle/grn-circle.png</href></Icon>
    </IconStyle>
    <LabelStyle><scale>0.9</scale></LabelStyle>
    <BalloonStyle>
      <text><![CDATA[<b>$[name]</b><br/>$[description]]]></text>
    </BalloonStyle>
  </Style>
  <Style id="style_ibz">
    <IconStyle>
